# ========================================
# CONFIGURACIÓN WEBHOOK WHATSAPP
# ========================================

# Token de acceso de WhatsApp Business API
# Obtenerlo desde: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID del número de teléfono de WhatsApp Business
# Formato: número sin espacios ni caracteres especiales
WHATSAPP_PHONE_ID=123456789012345

# Versión de la API de WhatsApp (opcional, default: v22.0)
WHATSAPP_API_VERSION=v22.0

# Token secreto para verificación del webhook
# Debe coincidir con el configurado en Meta for Developers
WHATSAPP_WEBHOOK_VERIFY_TOKEN=mi_token_secreto_abril_2024

# ========================================
# CONFIGURACIÓN BASE DE DATOS
# ========================================

# Host de PostgreSQL
DB_HOST=localhost

# Puerto de PostgreSQL
DB_PORT=5432

# Usuario de PostgreSQL
DB_USER=postgres

# Contraseña de PostgreSQL
DB_PASSWORD=tu_password_aqui

# Nombre de la base de datos
DB_NAME=whatsapp_db

# Logging de consultas SQL (true/false)
DB_LOGGING=false

# ========================================
# CONFIGURACIÓN SERVIDOR
# ========================================

# Puerto del servicio WS
PORT=3002

# Entorno (development/production)
NODE_ENV=development
